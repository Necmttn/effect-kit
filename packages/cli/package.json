{
  "name": "@effect-kit/cli",
  "version": "0.0.1",
  "description": "CLI for adding Effect services and components",
  "type": "module",
  "bin": {
    "effect-kit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "inquirer": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "cosmiconfig": "^9.0.0",
    "zod": "^3.23.0",
    "effect": "^3.16.10",
    "execa": "^9.4.0",
    "detect-package-manager": "^3.0.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "registry/**/*"
  ]
}