{
  "name": "@effect-kit/database",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@effect/platform": "^0.87.0",
    "@effect/sql": "^0.40.1",
    "@effect/sql-pg": "^0.38.3",
    "@effect/sql-mysql2": "^0.36.3",
    "@effect/sql-sqlite-node": "^0.34.2",
    "effect": "^3.16.10"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}